{
  "components": {
    "button": {
      "padding": { "$value": "0 {space.4}" },
      "font": { "$value": "{font.family.sans}" },

      "sizes": {
        "small": {
          "borderRadius": { "$value": "{radius.small}" },
          "height": { "$value": "{space.8}" },

          "padding": {
            "$value": "0 {space.4}",

            "iconOnly": { "$value": "0 {space.2}" }
          }
        },

        "medium": {
          "borderRadius": { "$value": "{radius.small}" },
          "height": { "$value": "{space.9}" },

          "padding": {
            "$value": "0 {space.6}",

            "iconOnly": { "$value": "0 {space.3}" }
          }
        },

        "large": {
          "borderRadius": { "$value": "{radius.small}" },
          "height": { "$value": "{space.10}" },

          "padding": {
            "$value": "0 {space.8}",

            "iconOnly": { "$value": "0 {space.4}" }
          }
        },

        "hero": {
          "borderRadius": {
            "min": { "$value": "{radius.small}" },
            "fluid": { "$value": "0.7vw" },
            "max": { "$value": "{radius.medium}" }
          },

          "fontSize": {
            "min": { "$value": "{typography.metrics.1.fontSize}" },
            "fluid": { "$value": "0.4vw + 0.92rem" },
            "max": { "$value": "{typography.metrics.3.fontSize}" }
          },

          "height": {
            "min": { "$value": "{space.9}" },
            "fluid": { "$value": "1.3vw + 2.2rem" },
            "max": { "$value": "{space.12}" }
          },

          "letterSpacing": {
            "min": { "$value": "{typography.metrics.1.letterSpacing}" },
            "fluid": { "$value": "0.002vw + 0.0095em" },
            "max": { "$value": "{typography.metrics.3.letterSpacing}" }
          },

          "lineHeight": {
            "min": { "$value": "{typography.metrics.1.lineHeight}" },
            "fluid": { "$value": "0.25vw + 1.25rem" },
            "max": { "$value": "{typography.metrics.3.lineHeight}" }
          },

          "padding": {
            "inline": {
              "min": { "$value": "{space.6}" },
              "fluid": { "$value": "1.8vw + 0.85rem" },
              "max": { "$value": "{space.10}" }
            },

            "iconOnly": {
              "inline": {
                "min": { "$value": "{space.3}" },
                "fluid": { "$value": "0.9vw + 0.5rem" },
                "max": { "$value": "{space.5}" }
              }
            }
          }
        }
      },

      "intents": {
        "light": {
          "primary": {
            "bg": { "$value": "{color.blue.400}" },
            "fg": { "$value": "{color.blue.400.fg}" },
            "hover": { "$value": "{color.blue.300}" }
          },

          "secondary": {
            "bg": { "$value": "{color.gray.400}" },
            "fg": { "$value": "{color.gray.400.fg}" },
            "hover": { "$value": "{color.gray.300}" }
          },

          "constructive": {
            "bg": { "$value": "{color.green.400}" },
            "fg": { "$value": "{color.green.400.fg}" },
            "hover": { "$value": "{color.green.300}" }
          },

          "destructive": {
            "bg": { "$value": "{color.red.400}" },
            "fg": { "$value": "{color.red.400.fg}" },
            "hover": { "$value": "{color.red.300}" }
          }
        },

        "dark": {
          "primary": {
            "bg": { "$value": "{color.blue.400}" },
            "fg": { "$value": "{color.blue.400.fg}" },
            "hover": { "$value": "lighten({color.blue.400}, .1)" }
          },

          "secondary": {
            "bg": { "$value": "{color.gray.400}" },
            "fg": { "$value": "{color.gray.400.fg}" },
            "hover": { "$value": "{color.gray.300}" }
          },

          "constructive": {
            "bg": { "$value": "{color.green.400}" },
            "fg": { "$value": "{color.green.400.fg}" },
            "hover": { "$value": "{color.green.300}" }
          },

          "destructive": {
            "bg": { "$value": "{color.red.400}" },
            "fg": { "$value": "{color.red.400.fg}" },
            "hover": { "$value": "{color.red.300}" }
          }
        }
      }
    }
  }
}
