{
  "components": {
    "copyButton": {
      "dark": {
        "bg": {
          "$value": "{color.black.20}",

          "hover": { "$value": "{color.black.10}" }
        },

        "fg": {
          "$value": "{theme.dark.text.muted}",

          "hover": { "$value": "{theme.dark.text.base}" }
        }
      },

      "light": {
        "bg": {
          "$value": "{color.white.20}",

          "hover": { "$value": "{color.white.10}" }
        },
        "fg": {
          "$value": "{theme.light.text.muted}",

          "hover": { "$value": "{theme.light.text.base}" }
        }
      }
    }
  }
}
